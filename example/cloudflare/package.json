{
  "name": "example-cloudflare",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "statikapi-cf --src src-api --out dist/worker.mjs",
    "wrangler:dev": "wrangler dev --local",
    "preview": "statikapi-cf preview --worker http://127.0.0.1:8787 --port 8788",
    "dev": "statikapi-cf dev --worker-port 8787 --port 8788",
    "deploy": "statikapi-cf deploy"
  },
  "devDependencies": {
    "@statikapi/adapter-cf": "workspace:*",
    "wrangler": "^4.47.0"
  }
}
