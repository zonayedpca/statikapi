{
  "name": "APP_NAME",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "statikapi-cf --src src-api --out dist/worker.mjs",
    "watch": "chokidar \"src-api/**/*.{js,mjs,cjs}\" -c \"pnpm build\"",
    "wrangler:dev": "wrangler dev --local --port 8787",
    "preview": "statikapi-cf preview --worker http://127.0.0.1:8787 --port 8788",
    "dev": "concurrently -n BUILD,WRANGLER,PREVIEW -c yellow,cyan,green \"pnpm watch\" \"pnpm wrangler:dev\" \"pnpm preview\"",
    "deploy": "wrangler deploy"
  },
  "devDependencies": {
    "@statikapi/adapter-cf": "^0.6.4",
    "wrangler": "^4.47.0",
    "concurrently": "^9.0.0",
    "chokidar-cli": "^3.0.0"
  }
}
